---
import Card__global from "./card__global.astro";
import video from "../assets/world.mp4";
---

<section
    id="ecosystem"
    class="flex flex-col-reverse lg:flex-row items-start lg:items-center justify-center h-auto md:h-dvh md:min-h-dvh w-full border-solid border-gray-500 border-t-[0.2px] lg:pt-10 gap-4 lg:gap-16"
>
    <article
        class="w-full lg:w-auto h-full flex flex-col items-center justify-center gap-4"
    >
        <Card__global
        number="01"
            title="Advisory"
            description="Provides institutional‑grade consulting on bullion programs, operational design, and governance frameworks for intermediaries and their clients"
            
        />
        <Card__global
        number="02"
            title="Vault"
            description="Coordinates custody with independent approved depositories, ensuring account‑level segregation, no commingling, and clear ownership at all times"
            
        />
        <Card__global
            number="03"
            title="Technology"
            description="Delivers the infrastructure that routes instructions, reconciles positions, and provides reporting, without holding client funds or assets"
            
        />
        <Card__global
        number="04"
        title="Proprietary Trading"
            description="Executes market activity strictly with WiseGold capital, supporting liquidity and discipline without using client assets or acting as a retail broker"
            
        />
    </article>
    <article
        class="w-auto lg:w-2/3 h-auto pt-3 flex flex-col items-center lg:items-right px-4 justify-end lg:pl-32"
    >
        <h2
            class="text-4xl w-auto md:text-5xl font-medium text-white-700 uppercase font-bebas-neue leading-tight lg:leading-14 mt-2 text-left lg:text-right w-full"
        >
            Worldwide Depository & Counterparty Framework
        </h2>
        <p
            class="text-gray-500 lg:mt-3 text-sm md:text-base text-left lg:text-right w-full"
        >
            Strategic access to independent depositories, logistics routes, and
            institutional counterparties across key jurisdictions
        </p>
    </article>
</section>

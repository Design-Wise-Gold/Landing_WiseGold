---
import video from "../assets/world.mp4";
---

<section
    id="custody"
    class="flex flex-col items-center justify-center h-auto  w-full pt-12 pb-10 lg:py-24 gap-6"
>
    <article
        class="w-full h-auto flex flex-col items-center justify-center gap-2 px-4"
    >
        <h2
            class="text-4xl md:text-5xl font-medium text-white-700 uppercase font-bebas-neue leading-tight lg:leading-14 mt-2 text-left lg:text-center w-full"
        >
            Institutional Grade Segregation & Custody Control
        </h2>
        <p
            class="text-gray-300 lg:mt-3 text-sm md:text-base text-left lg:text-center w-full lg:w-2/3"
        >
            A unified ecosystem encompassing advisory, independent vault
            coordination, technology, and proprietary trading. Engineered
            exclusively for capital preservation and institutional continuity
        </p>
    </article>
    <article class="w-full h-96 flex flex-col items-center px-4 justify-center">
        <video
            src={video}
            autoplay
            muted
            loop
            playsinline
            class="w-full h-full object-cover"
        >
        </video>
    </article>
</section>

---
const { title, description, video } = Astro.props;
---

<div
    class="group relative flex flex-col-reverse lg:flex-row items-left justify-left gap-2 border border-gray-500 h-auto w-full lg:w-auto hover:border-accent transition-all duration-300"
>
    <div class="flex flex-col p-2 h-auto w-full lg:w-auto">
        <span
            class="text-gray-300 group-hover:text-white font-semibold transition-colors duration-300"
            >{title}</span
        >
        <p
            class="text-gray-400 group-hover:text-gray-300 lg:mt-3 text-sm text-left w-full lg:w-2/3 transition-colors duration-300"
        >
            {description}
        </p>
    </div>
    <video
        src={video}
        autoplay
        muted
        loop
        playsinline
        class="w-full lg:absolute  right-0 lg:w-40 h-32 lg:h-full object-cover transition-all duration-400 group-hover:lg:w-80 group-hover:lg:h-[130%] group-hover:lg:right-[-30%] group-hover:lg:top-[-15%]"
    >
    </video>
</div>

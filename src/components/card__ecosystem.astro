---
const { title, description, video } = Astro.props;
---

<div class="flex flex-col lg:flex-row items-left justify-left gap-2 border border-gray-500  w-full lg:w-auto">
    <div class="flex flex-col p-2 w-full lg:w-auto">
        <span class="text-gray-300 ">{title}</span>
        <p
            class="text-gray-500 lg:mt-3 text-sm  text-left w-full lg:w-2/3"
        >
            {description}
        </p>
    </div>
    <video
        src={video}
        autoplay
        muted
        loop
        playsinline
        class="w-full lg:w-40 h-16 lg:h-full object-cover hover:scale-150 transition-all duration-300"></video>
</div>

---

---

<section
    id="intermediaries"
    class="flex flex-col lg:flex-row items-start justify-between h-auto lg:h-dvh w-full py-12 pt-20 px-4 lg:px-12 bg-accent gap-8 lg:gap-12"
>
    <!-- Left Column: Header + Form -->
    <div class="flex flex-col justify-between w-full lg:w-3/5 h-full gap-8">
        <!-- Header -->
        <article class="w-full flex flex-col items-start justify-center gap-3">
            <h4
                class="text-3xl md:text-5xl font-medium text-black-900 uppercase font-bebas-neue leading-tight lg:leading-14"
            >
                Exclusive Infrastructure for Approved Intermediaries
            </h4>
            <p class="text-black-900/60 text-sm md:text-base w-full lg:w-4/5">
                WiseGold provides operational infrastructure exclusively through
                vetted professional intermediaries
            </p>
        </article>

        <!-- Contact Form -->
        <form class="w-full flex flex-col gap-5 border border-black-900/20 p-6">
            <div class="flex flex-col lg:flex-row lg:items-center gap-1 lg:gap-4">
                <label class="text-black-900 text-xs font-bold uppercase lg:w-48 shrink-0">Legal Name of Firm</label>
                <input
                    type="text"
                    placeholder="Enter legal name..."
                    class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors w-full"
                />
            </div>
            <div class="flex flex-col lg:flex-row lg:items-center gap-1 lg:gap-4">
                <label class="text-black-900 text-xs font-bold uppercase lg:w-48 shrink-0">Primary Contact Name</label>
                <input
                    type="text"
                    placeholder="Enter primary contact name..."
                    class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors w-full"
                />
            </div>
            <div class="flex flex-col lg:flex-row lg:items-center gap-1 lg:gap-4">
                <label class="text-black-900 text-xs font-bold uppercase lg:w-48 shrink-0">Business Email</label>
                <input
                    type="email"
                    placeholder="Enter business email..."
                    class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors w-full"
                />
            </div>
            <div class="flex flex-col lg:flex-row lg:items-center gap-1 lg:gap-4">
                <label class="text-black-900 text-xs font-bold uppercase lg:w-48 shrink-0">Phone Number</label>
                <input
                    type="tel"
                    placeholder="Enter phone number..."
                    class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors w-full"
                />
            </div>
        </form>

        <!-- Submit Button -->
        <div class="flex justify-center lg:justify-end">
            <button
                type="submit"
                class="flex items-center justify-center gap-2 bg-black-900 text-accent py-3 px-8 hover:bg-gray-900 transition-colors duration-300"
            >
                <span class="text-sm font-medium">Apply for Intermediary Access</span>
                <svg
                    class="w-5"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path
                        d="M11 9a1 1 0 0 0 1-1V5.061a1 1 0 0 1 1.811-.75l6.836 6.836a1.207 1.207 0 0 1 0 1.707l-6.836 6.835a1 1 0 0 1-1.811-.75V16a1 1 0 0 0-1-1H9a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1z"
                    ></path>
                    <path d="M4 9v6"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Right Column: Info Cards (desktop) -->
    <div class="flex flex-col w-full lg:w-2/5 gap-4 h-full justify-start pt-0 lg:pt-2">
        <!-- Who We Serve -->
        <article class="border border-black-900/30 p-5 flex flex-col gap-2">
            <h3 class="text-black-900 font-bold text-sm">Who We Serve</h3>
            <ul class="text-black-900/70 text-xs flex flex-col gap-1 list-disc list-inside">
                <li>Financial advisors structuring bullion programs</li>
                <li>Family offices and high-net-worth fiduciaries</li>
                <li>Institutional brokers and intermediaries</li>
                <li>Wealth managers requiring custody infrastructure</li>
            </ul>
        </article>

        <!-- What We Provide -->
        <article class="border border-black-900/30 p-5 flex flex-col gap-2">
            <h3 class="text-black-900 font-bold text-sm">What We Provide</h3>
            <ul class="text-black-900/70 text-xs flex flex-col gap-1 list-disc list-inside">
                <li>Operational coordination and technology access</li>
                <li>Compliance and governance frameworks</li>
                <li>Segregated custody and logistics support</li>
                <li>No direct client relationship or asset management</li>
            </ul>
        </article>

        <!-- Onboarding Process -->
        <article class="border border-black-900/30 p-5 flex flex-col gap-2">
            <h3 class="text-black-900 font-bold text-sm">Onboarding Process</h3>
            <ol class="text-black-900/70 text-xs flex flex-col gap-1 list-decimal list-inside">
                <li>Intermediary application and due diligence</li>
                <li>Governance and compliance review</li>
                <li>Technology platform access and training</li>
                <li>Live operational support activation</li>
            </ol>
        </article>
    </div>
</section>
---

---

<section
    id="intermediaries"
    class="flex flex-col items-center justify-between h-dvh w-full py-12 pt-20 px-4  bg-accent"
>
    <!-- Header -->
    <article class="w-full flex flex-col items-center justify-center gap-3 text-center">
        <h4
            class="text-3xl md:text-5xl font-medium text-white-700 uppercase font-bebas-neue leading-tight lg:leading-14"
        >
            Exclusive Infrastructure for<br />Approved Intermediaries
        </h4>
        <p class="text-gray-500 text-sm md:text-base w-full lg:w-2/3">
            WiseGold provides operational infrastructure exclusively through
            vetted professional intermediaries
        </p>
    </article>

    <!-- Onboarding Process -->
    <article
        class="w-full lg:w-2/3 border border-accent p-6 flex flex-col gap-3"
    >
        <h3 class="text-white-700 font-bold text-base">Onboarding Process</h3>
        <ol class="list-decimal list-inside text-gray-400 text-sm flex flex-col gap-1.5">
            <li>Intermediary application and due diligence</li>
            <li>Governance and compliance review</li>
            <li>Technology platform access and training</li>
            <li>Live operational support activation</li>
        </ol>
    </article>

    <!-- Contact Form -->
    <form
        class="w-full lg:w-2/3  flex flex-col gap-5 p-6"
    >
        <div class="flex flex-col gap-1">
            <label class="text-black-900 text-xs font-bold uppercase">Legal Name of Firm</label>
            <input
                type="text"
                placeholder="Enter legal name..."
                class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors"
            />
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-black-900 text-xs font-bold uppercase">Primary Contact Name</label>
            <input
                type="text"
                placeholder="Enter primary contact name..."
                class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors"
            />
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-black-900 text-xs font-bold uppercase">Business Email</label>
            <input
                type="email"
                placeholder="Enter business email..."
                class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors"
            />
        </div>
        <div class="flex flex-col gap-1">
            <label class="text-black-900 text-xs font-bold uppercase">Phone Number</label>
            <input
                type="tel"
                placeholder="Enter phone number..."
                class="bg-transparent border-b border-black-900/30 text-black-900 placeholder-black-900/50 text-sm py-2 outline-none focus:border-black-900 transition-colors"
            />
        </div>

        <!-- Submit Button -->
        <button
            type="submit"
            class="flex items-center justify-center gap-2 w-full bg-black-900 text-accent py-3 px-6 mt-2 hover:bg-gray-900 transition-colors duration-300"
        >
            <span class="text-sm font-medium">Apply for Intermediary Access</span>
            <svg
                class="w-5"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
            >
                <path
                    d="M11 9a1 1 0 0 0 1-1V5.061a1 1 0 0 1 1.811-.75l6.836 6.836a1.207 1.207 0 0 1 0 1.707l-6.836 6.835a1 1 0 0 1-1.811-.75V16a1 1 0 0 0-1-1H9a1 1 0 0 1-1-1v-4a1 1 0 0 1 1-1z"
                ></path>
                <path d="M4 9v6"></path>
            </svg>
        </button>
    </form>
</section>
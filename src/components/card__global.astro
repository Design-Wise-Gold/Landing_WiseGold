---
const { title, description, number } = Astro.props;
---

<div
    class="group relative flex flex-col lg:flex-row items-left justify-left gap-0.5 lg:gap-2 border border-gray-500 w-full lg:w-auto hover:border-accent transition-all duration-300 p-4"
>
    <div class="flex flex-col w-full lg:w-auto">
        <span
            class="text-gray-400 font-black group-hover:text-gray-300 transition-colors duration-300 text-2xl lg:text-7xl w-24"
            >{number}</span
        >
    </div>
    <div class="flex flex-col w-full gap-0.5">
        <h3
            class="text-gray-400 font-bold group-hover:text-white-700 text-sm text-left w-full transition-colors duration-300"
        >
            {title}
        </h3>
        <p
            class="text-gray-500 group-hover:text-gray-300 lg:mt-3 text-sm text-left w-full  transition-colors duration-300"
        >
            {description}
        </p>
    </div>
</div>

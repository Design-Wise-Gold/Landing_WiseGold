<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Urbanist:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
		<title>WiseGold</title>
		
	</head>
	<body>
		<!-- Gold bullion particle canvas — full page -->
		<canvas id="gold-matrix" class="fixed inset-0 w-full h-full pointer-events-none z-[9999]" style="opacity:0.30"></canvas>
		<slot />
	</body>
</html>

<script>
(function () {
  const canvas = document.getElementById("gold-matrix") as HTMLCanvasElement | null;
  if (!canvas) return;
  const ctx = canvas.getContext("2d");
  if (!ctx) return;

  interface Particle {
    x: number; y: number;
    vx: number; vy: number;
    rotation: number;
    rotationSpeed: number;
    w: number; h: number;
    alpha: number;
    life: number; maxLife: number;
    baseColor: string;
    highlightColor: string;
    gravity: number;
    friction: number;
  }

  // Gold palette — base + highlight for 3D ingot look
  const PALETTE = [
    { base: "#b48b1e", hi: "#f5d66b" },
    { base: "#d4a017", hi: "#ffe066" },
    { base: "#a67c00", hi: "#ffd700" },
    { base: "#c9981a", hi: "#ffe599" },
    { base: "#8c6d1f", hi: "#e6c84d" },
  ];

  let mouse = { x: -9999, y: -9999 };
  let mouseVel = { x: 0, y: 0 };
  let prevMouse = { x: -9999, y: -9999 };
  let particles: Particle[] = [];
  let rafId: number;
  const MAX_PARTICLES = 80;
  const SPAWN_RADIUS = 50;
  const FRICTION = 0.8;
  const GRAVITY = 0.08;

  function resize() {
    canvas!.width = window.innerWidth;
    canvas!.height = window.innerHeight;
  }

  function spawnParticle() {
    if (particles.length >= MAX_PARTICLES) return;
    if (mouse.x < 0) return;

    // Only spawn when mouse is moving
    const speed = Math.sqrt(mouseVel.x * mouseVel.x + mouseVel.y * mouseVel.y);
    if (speed < 0.8) return;

    // Spawn near cursor with slight random offset
    const offsetAngle = Math.random() * Math.PI * 2;
    const offsetR = Math.random() * SPAWN_RADIUS;
    const x = mouse.x + Math.cos(offsetAngle) * offsetR;
    const y = mouse.y + Math.sin(offsetAngle) * offsetR;

    // Velocity inherits mouse direction + some spread
    const spread = 0.6;
    const vx = mouseVel.x * (0.3 + Math.random() * 0.4) + (Math.random() - 0.5) * spread;
    const vy = mouseVel.y * (0.3 + Math.random() * 0.4) + (Math.random() - 0.5) * spread;

    const palette = PALETTE[Math.floor(Math.random() * PALETTE.length)];
    const maxLife = 60 + Math.random() * 80;

    // Small rectangles: width 4-10px, height 2-5px (ingot proportions ~2:1)
    const w = 4 + Math.random() * 6;
    const h = 2 + Math.random() * 3;

    particles.push({
      x, y, vx, vy,
      rotation: Math.random() * Math.PI * 2,
      rotationSpeed: (Math.random() - 0.5) * 0.08,
      w, h,
      alpha: 0,
      life: 0,
      maxLife,
      baseColor: palette.base,
      highlightColor: palette.hi,
      gravity: GRAVITY + Math.random() * 0.02,
      friction: FRICTION + (Math.random() - 0.5) * 0.005,
    });
  }

  function drawIngot(p: Particle, alpha: number) {
    ctx!.save();
    ctx!.translate(p.x, p.y);
    ctx!.rotate(p.rotation);

    // Main body
    ctx!.fillStyle = p.baseColor;
    ctx!.globalAlpha = alpha;
    ctx!.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);

    // Top highlight edge (makes it look 3D)
    ctx!.fillStyle = p.highlightColor;
    ctx!.globalAlpha = alpha * 0.7;
    ctx!.fillRect(-p.w / 2, -p.h / 2, p.w, p.h * 0.35);

    // Left highlight edge
    ctx!.globalAlpha = alpha * 0.4;
    ctx!.fillRect(-p.w / 2, -p.h / 2, p.w * 0.15, p.h);

    ctx!.restore();
  }

  function draw() {
    ctx!.clearRect(0, 0, canvas!.width, canvas!.height);

    // Spawn particles based on mouse speed
    const speed = Math.sqrt(mouseVel.x * mouseVel.x + mouseVel.y * mouseVel.y);
    const spawnCount = Math.min(Math.floor(speed * 0.4), 4);
    for (let i = 0; i < spawnCount; i++) spawnParticle();

    particles = particles.filter((p) => {
      p.life++;

      // Physics: apply velocity, gravity, friction
      p.vy += p.gravity;
      p.vx *= p.friction;
      p.vy *= p.friction;
      p.x += p.vx;
      p.y += p.vy;
      p.rotation += p.rotationSpeed;

      // Fade in / fade out
      const progress = p.life / p.maxLife;
      if (progress < 0.15) {
        p.alpha = (progress / 0.15);
      } else if (progress > 0.65) {
        p.alpha = (1 - progress) / 0.35;
      } else {
        p.alpha = 1;
      }

      // Proximity glow
      const dx = p.x - mouse.x;
      const dy = p.y - mouse.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      const proximity = Math.max(0, 1 - dist / 200);

      const alpha = p.alpha * (0.4 + proximity * 0.6) * 0.85;

      // Glow when near cursor
      if (proximity > 0.2) {
        ctx!.shadowColor = `rgba(255,215,0,${proximity * 0.6})`;
        ctx!.shadowBlur = 8 * proximity;
      } else {
        ctx!.shadowBlur = 0;
      }

      drawIngot(p, alpha);
      ctx!.shadowBlur = 0;
      ctx!.globalAlpha = 1;

      return p.life < p.maxLife;
    });

    // Decay mouse velocity over time
    mouseVel.x *= 0.92;
    mouseVel.y *= 0.92;

    rafId = requestAnimationFrame(draw);
  }

  // Track mouse position + velocity
  document.addEventListener("mousemove", (e: MouseEvent) => {
    if (prevMouse.x > -9000) {
      mouseVel.x = e.clientX - prevMouse.x;
      mouseVel.y = e.clientY - prevMouse.y;
    }
    prevMouse.x = e.clientX;
    prevMouse.y = e.clientY;
    mouse.x = e.clientX;
    mouse.y = e.clientY;
  });

  document.addEventListener("mouseleave", () => {
    mouse.x = -9999;
    mouse.y = -9999;
    prevMouse.x = -9999;
    prevMouse.y = -9999;
    mouseVel.x = 0;
    mouseVel.y = 0;
  });

  window.addEventListener("resize", () => {
    cancelAnimationFrame(rafId);
    resize();
    draw();
  });

  resize();
  draw();
})();
</script>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		background-color: var(--color-black-900);
		box-sizing: border-box;
		font-family: var(--font-urbanist);
		scroll-behavior: smooth;
	}
</style>
